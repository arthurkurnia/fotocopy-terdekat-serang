    <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <script>
        AOS.init({ duration: 1000, once: true });

        window.addEventListener('scroll', function() {
            const scrollPos = window.pageYOffset;
            const textElement = document.getElementById('parallaxContent');
            
            // Gerak halus saat scroll naik turun
            textElement.style.transform = `translateY(${scrollPos * 0.15}px)`;
            
            const opacityValue = 1 - (scrollPos / 600);
            textElement.style.opacity = opacityValue > 0 ? opacityValue : 0;
        });
    </script>
